<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { padding: 20px; border: 1px solid #ddd; border-radius: 5px; max-width: 600px; margin: auto; }
        .header { background-color: #f4f4f4; padding: 10px; text-align: center; }
        .otp { font-size: 24px; font-weight: bold; color: #007bff; text-align: center; margin: 20px 0; }
        .footer { font-size: 12px; color: #777; text-align: center; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>Verify Your Email</h2>
        </div>
        <p>Hello,</p>
        <p>Thank you for registering. Please use the following One-Time Password (OTP) to verify your email address:</p>
        <div class="otp"><%= otp %></div>
        <p>This code will expire in <strong><%= expiresAt %> minutes</strong>.</p>
        <p>If you did not request this, please ignore this email.</p>
        <div class="footer">
            &copy; <%= new Date().getFullYear() %> FX Trade. All rights reserved.
        </div>
    </div>
</body>
</html>
